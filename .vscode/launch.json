{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Langbridge Runtime Host",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "langbridge.cli.main",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "serve",
                "--config",
                "examples/runtime_host/langbridge_config.yml",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Langbridge Runtime Host (MCP)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "langbridge.cli.main",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "serve",
                "--config",
                "examples/runtime_host/langbridge_config.yml",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--features",
                "mcp",
                "--debug"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Langbridge Runtime Host (UI + MCP)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "langbridge.cli.main",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "serve",
                "--config",
                "examples/runtime_host/langbridge_config.yml",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--features",
                "ui,mcp",
                "--debug"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
